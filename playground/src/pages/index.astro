---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const home = await getEntry('pages', 'home');
const sections = home?.data.sections ?? [];
const Content = home ? (await render(home)).Content : null;
---

<Base title={home?.data.title ?? 'Home'} description={home?.data.description}>
  {sections.map((section) => {
    if (section.type === 'hero') return (
      <section class="relative bg-gradient-to-b from-violet-50 to-stone-50 py-24 overflow-hidden">
        <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
          <div class="flex-1 text-center md:text-left">
            <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-stone-900">{section.heading}</h1>
            {section.subheading && <p class="mt-4 text-lg text-stone-500 max-w-xl">{section.subheading}</p>}
            {section.buttonText && section.buttonUrl && (
              <a href={section.buttonUrl} class="mt-8 inline-block bg-violet-600 hover:bg-violet-700 text-white font-medium px-8 py-3 rounded-lg transition-colors">
                {section.buttonText}
              </a>
            )}
          </div>
          {section.image && (
            <div class="flex-1 max-w-md">
              <img src={section.image} alt={section.heading} class="rounded-2xl shadow-xl w-full" />
            </div>
          )}
        </div>
      </section>
    );

    if (section.type === 'features') return (
      <section class="py-20">
        <div class="max-w-5xl mx-auto px-6">
          {section.heading && <h2 class="text-2xl font-semibold text-stone-900 text-center mb-12">{section.heading}</h2>}
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {section.items.map((item) => (
              <div class="bg-white border border-stone-200 rounded-xl p-6">
                {item.icon && <img src={item.icon} alt="" class="w-8 h-8 mb-4" />}
                <h3 class="font-semibold text-stone-900">{item.title}</h3>
                {item.description && <p class="mt-2 text-sm text-stone-500">{item.description}</p>}
              </div>
            ))}
          </div>
        </div>
      </section>
    );

    if (section.type === 'image') return (
      <section class="py-12">
        <div class="max-w-4xl mx-auto px-6">
          <figure>
            <img src={section.src} alt={section.alt ?? ''} class="w-full rounded-2xl shadow-lg" />
            {section.caption && <figcaption class="mt-3 text-center text-sm text-stone-400">{section.caption}</figcaption>}
          </figure>
        </div>
      </section>
    );

    if (section.type === 'testimonials') return (
      <section class="py-20 bg-stone-50">
        <div class="max-w-5xl mx-auto px-6">
          {section.heading && <h2 class="text-2xl font-semibold text-stone-900 text-center mb-12">{section.heading}</h2>}
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {section.items.map((item) => (
              <div class="bg-white border border-stone-200 rounded-xl p-6">
                <p class="text-stone-600 italic">"{item.quote}"</p>
                <div class="mt-4 flex items-center gap-3">
                  {item.avatar && <img src={item.avatar} alt={item.name} class="w-10 h-10 rounded-full" />}
                  <div>
                    <p class="font-semibold text-stone-900 text-sm">{item.name}</p>
                    {item.role && <p class="text-xs text-stone-400">{item.role}</p>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );

    if (section.type === 'pricing') return (
      <section class="py-20">
        <div class="max-w-5xl mx-auto px-6">
          {section.heading && <h2 class="text-2xl font-semibold text-stone-900 text-center mb-12">{section.heading}</h2>}
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {section.items.map((item) => (
              <div class:list={['border rounded-xl p-6 flex flex-col', item.featured ? 'border-violet-400 bg-violet-50 ring-2 ring-violet-200' : 'border-stone-200 bg-white']}>
                <h3 class="font-semibold text-stone-900 text-lg">{item.plan}</h3>
                <p class="mt-2 text-3xl font-bold text-stone-900">{item.price}</p>
                {item.description && <p class="mt-2 text-sm text-stone-500">{item.description}</p>}
                <div class="mt-auto pt-6">
                  <a href={item.buttonUrl} class:list={['block text-center font-medium px-6 py-3 rounded-lg transition-colors', item.featured ? 'bg-violet-600 hover:bg-violet-700 text-white' : 'bg-stone-100 hover:bg-stone-200 text-stone-700']}>
                    {item.buttonText}
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );

    if (section.type === 'cta') return (
      <section class="py-20 bg-stone-900 text-white">
        <div class="max-w-3xl mx-auto px-6 text-center">
          <h2 class="text-2xl font-semibold">{section.heading}</h2>
          {section.description && <p class="mt-3 text-stone-300">{section.description}</p>}
          <a href={section.buttonUrl} class="mt-8 inline-block bg-violet-600 hover:bg-violet-700 text-white font-medium px-8 py-3 rounded-lg transition-colors">
            {section.buttonText}
          </a>
        </div>
      </section>
    );
  })}

  {Content && (
    <section class="py-16">
      <div class="max-w-3xl mx-auto px-6 prose prose-stone">
        <Content />
      </div>
    </section>
  )}
</Base>
