---
import { ClientRouter } from 'astro:transitions';
import config from 'virtual:mimsy/config';
import pages from 'virtual:mimsy/pages';
import { createAdapter, getEnv } from '../../adapters/factory.js';
import MediaLibrary from '../../components/MediaLibrary.svelte';
import '/src/styles/global.css';

interface Props {
  title: string;
  activeCollection?: string;
  activePage?: string;
  fullWidth?: boolean;
}

const { title, activeCollection, activePage, fullWidth = false } = Astro.props;

const adapter = await createAdapter(Astro.request, Astro.locals);
const collections = await adapter.listCollections();
const user = Astro.locals.mimsyUser;
const isGitHubMode = !!getEnv('MIMSY_GITHUB_REPO');
const isR2 = config.media?.storage === 'r2';
const showMedia = isR2 || !isGitHubMode;
const showDeploy = !!getEnv('MIMSY_DEPLOY_HOOK_URL');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | MimsyCMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body class="mimsy-admin bg-stone-50 min-h-screen text-stone-800 antialiased">
  <!-- Mobile header -->
  <header class="mimsy-mobile-header lg:hidden fixed top-0 inset-x-0 z-50 h-14 bg-stone-900 flex items-center justify-between px-4">
    <a href={config.basePath} class="font-serif text-lg text-stone-100 tracking-tight">Mimsy</a>
    <button
      type="button"
      class="mimsy-menu-toggle text-stone-400 hover:text-stone-100 transition-colors p-1"
      aria-label="Toggle navigation"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
    </button>
  </header>

  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="mimsy-sidebar fixed inset-y-0 left-0 z-40 w-60 bg-stone-900 text-stone-300 flex flex-col -translate-x-full lg:translate-x-0 lg:static lg:z-auto transition-transform duration-200 ease-out" transition:persist>
      <!-- Brand -->
      <div class="h-14 flex items-center px-5 border-b border-stone-800/60">
        <a href={config.basePath} class="group flex items-center gap-2.5">
          <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-violet-600 text-white font-serif text-sm font-medium">M</span>
          <span class="font-serif text-lg text-stone-100 tracking-tight">Mimsy</span>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-3 pt-5 pb-3 overflow-y-auto">
        {pages.length > 0 && (
          <>
            <p class="px-2 mb-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-stone-500">Site Pages</p>
            <ul class="space-y-0.5 mb-4">
              {pages.map((page) => {
                const isActive = activePage === page.path;
                return (
                  <li>
                    <a
                      href={`${config.basePath}/_page/${page.path}`}
                      data-page={page.path}
                      data-active={isActive ? '' : undefined}
                      class="mimsy-nav-link group flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-[13px] font-medium transition-all duration-150"
                    >
                      <span class="mimsy-nav-dot w-1 h-4 rounded-full transition-all duration-150" />
                      {page.name}
                    </a>
                  </li>
                );
              })}
            </ul>
          </>
        )}
        <p class="px-2 mb-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-stone-500">Collections</p>
        <ul class="space-y-0.5">
          {collections.map((col) => {
            const isActive = activeCollection === col;
            return (
              <li>
                <a
                  href={`${config.basePath}/${col}`}
                  data-collection={col}
                  data-active={isActive ? '' : undefined}
                  class="mimsy-nav-link group flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-[13px] font-medium transition-all duration-150"
                >
                  <span class="mimsy-nav-dot w-1 h-4 rounded-full transition-all duration-150" />
                  {col.charAt(0).toUpperCase() + col.slice(1)}
                </a>
              </li>
            );
          })}
        </ul>
        {showMedia && (
          <>
            <p class="px-2 mt-4 mb-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-stone-500">Assets</p>
            <ul class="space-y-0.5">
              <li>
                <a
                  href={config.basePath + '/media'}
                  class="mimsy-nav-link group flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-[13px] font-medium transition-all duration-150"
                >
                  <span class="mimsy-nav-dot w-1 h-4 rounded-full transition-all duration-150" />
                  Media
                </a>
              </li>
            </ul>
          </>
        )}
      </nav>

      <!-- Footer -->
      <div class="px-5 py-3.5 border-t border-stone-800/60">
        {user ? (
          <div class="flex items-center gap-2.5 mb-2">
            <img src={user.avatar} alt="" class="w-6 h-6 rounded-full" />
            <span class="text-xs text-stone-400 truncate flex-1">{user.name}</span>
            <a href="/api/mimsy/auth/logout" class="text-[10px] text-stone-600 hover:text-stone-400 transition-colors">Logout</a>
          </div>
        ) : null}
        {showDeploy && (
          <button
            id="mimsy-deploy-btn"
            type="button"
            class="mb-2.5 w-full flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md bg-violet-600 hover:bg-violet-500 disabled:opacity-60 text-white text-xs font-medium transition-colors cursor-pointer disabled:cursor-default"
            style="border:none;cursor:pointer;"
          >
            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/></svg>
            <span>Deploy</span>
          </button>
        )}
        <p class="text-[10px] text-stone-600 tracking-wide">MimsyCMS <span class="text-stone-700">v0.0.1</span></p>
      </div>
    </aside>

    <!-- Overlay for mobile sidebar -->
    <div class="mimsy-sidebar-overlay fixed inset-0 z-30 bg-stone-900/50 backdrop-blur-sm opacity-0 pointer-events-none lg:hidden transition-opacity duration-200"></div>

    <!-- Main content -->
    <main class="flex-1 min-w-0 pt-14 lg:pt-0">
      {fullWidth ? (
        <div class="h-full">
          <slot />
        </div>
      ) : (
        <div class="max-w-7xl mx-auto px-5 py-7 lg:px-8 lg:py-9">
          <slot />
        </div>
      )}
    </main>
  </div>

  <!-- Media picker (always in DOM, shown via mimsy:media:open event) -->
  <div id="mimsy-media-picker-mount">
    <MediaLibrary
      mode="picker"
      basePath={config.basePath}
      isR2={isR2}
      client:only="svelte"
    />
  </div>

  <!-- Global toast container (survives View Transitions) -->
  <div id="mimsy-toasts" class="mimsy-toast-container" transition:persist></div>

  <!-- Command palette -->
  <div id="mimsy-palette" class="mimsy-palette-overlay" data-basepath={config.basePath} hidden>
    <div class="mimsy-palette-panel">
      <div class="mimsy-palette-input-wrap">
        <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
        <input id="mimsy-palette-input" class="mimsy-palette-input" placeholder="Search entries…" autocomplete="off" />
        <kbd class="mimsy-palette-kbd">Esc</kbd>
      </div>
      <div id="mimsy-palette-results" class="mimsy-palette-results"></div>
    </div>
  </div>

  <script is:inline>
    if (!window.__mimsyInit) {
      window.__mimsyInit = true;

      // ── Mobile sidebar toggle ──
      document.addEventListener('click', function(e) {
        var toggle = e.target.closest('.mimsy-menu-toggle');
        var sidebar = document.querySelector('.mimsy-sidebar');
        var overlay = document.querySelector('.mimsy-sidebar-overlay');
        if (!sidebar || !overlay) return;
        if (toggle) {
          var isOpen = !sidebar.classList.contains('-translate-x-full');
          sidebar.classList.toggle('-translate-x-full', isOpen);
          overlay.classList.toggle('opacity-0', isOpen);
          overlay.classList.toggle('pointer-events-none', isOpen);
        }
        if (e.target.closest('.mimsy-sidebar-overlay')) {
          sidebar.classList.add('-translate-x-full');
          overlay.classList.add('opacity-0', 'pointer-events-none');
        }
      });

      // ── Close sidebar on navigation (view transitions) ──
      document.addEventListener('astro:before-preparation', function(e) {
        var sidebar = document.querySelector('.mimsy-sidebar');
        var overlay = document.querySelector('.mimsy-sidebar-overlay');
        if (sidebar && overlay && window.innerWidth < 1024) {
          sidebar.classList.add('-translate-x-full');
          overlay.classList.add('opacity-0', 'pointer-events-none');
        }
        // Block navigation if editor has unsaved draft
        if (document.body.hasAttribute('data-mimsy-dirty')) {
          if (!confirm('You have unsaved changes. Discard them?')) {
            e.preventDefault();
            return;
          }
          document.body.removeAttribute('data-mimsy-dirty');
          // Clear draft from sessionStorage
          var keys = [];
          for (var i = 0; i < sessionStorage.length; i++) {
            var key = sessionStorage.key(i);
            if (key && key.indexOf('mimsy-draft-') === 0) keys.push(key);
          }
          for (var j = 0; j < keys.length; j++) sessionStorage.removeItem(keys[j]);
          // Clear Vite server draft (fire-and-forget)
          fetch('/__mimsy_draft', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'clear' }),
          }).catch(function() {});
        }
      });

      // ── Update active nav highlight after view transition ──
      function updateSidebarActive() {
        var path = window.location.pathname;
        document.querySelectorAll('.mimsy-nav-link').forEach(function(link) {
          var href = link.getAttribute('href');
          if (!href) return;
          var isActive = path === href || path.startsWith(href + '/');
          if (isActive) link.setAttribute('data-active', '');
          else link.removeAttribute('data-active');
        });
      }
      document.addEventListener('astro:after-swap', updateSidebarActive);

      // ── Global Cmd+S prevention ──
      document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 's') e.preventDefault();
      });

      // ── Global Toast System ──
      function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      window.addEventListener('mimsy:toast', function(e) {
        var container = document.getElementById('mimsy-toasts');
        if (!container) return;
        var detail = e.detail || {};
        var msg = detail.message || '';
        var type = detail.type || 'success';

        var toast = document.createElement('div');
        toast.className = 'mimsy-toast-item mimsy-toast-' + type;

        var iconSvg = type === 'success'
          ? '<svg class="mimsy-toast-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4.5 12.75 6 6 9-13.5"/></svg>'
          : '<svg class="mimsy-toast-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>';

        var closeBtn = type === 'error'
          ? '<button class="mimsy-toast-close" aria-label="Dismiss">&times;</button>'
          : '';

        toast.innerHTML = iconSvg + '<span>' + escapeHtml(msg) + '</span>' + closeBtn;

        // Close button for error toasts
        if (type === 'error') {
          toast.querySelector('.mimsy-toast-close').addEventListener('click', function() {
            toast.classList.remove('mimsy-toast-visible');
            setTimeout(function() { toast.remove(); }, 200);
          });
        }

        container.appendChild(toast);

        // Trigger enter animation
        requestAnimationFrame(function() {
          toast.classList.add('mimsy-toast-visible');
        });

        // Auto-dismiss success toasts after 3s
        if (type === 'success') {
          setTimeout(function() {
            toast.classList.remove('mimsy-toast-visible');
            setTimeout(function() { toast.remove(); }, 200);
          }, 3000);
        }
      });

      // ── Command Palette (Cmd+K) ──
      var paletteCache = null;
      var paletteCacheTime = 0;

      function openPalette() {
        var overlay = document.getElementById('mimsy-palette');
        var input = document.getElementById('mimsy-palette-input');
        if (!overlay || !input) return;
        overlay.hidden = false;
        input.value = '';
        input.focus();
        renderPaletteResults('');
        // Fetch data if stale (>30s)
        if (!paletteCache || Date.now() - paletteCacheTime > 30000) fetchPaletteData();
      }

      function closePalette() {
        var overlay = document.getElementById('mimsy-palette');
        if (overlay) overlay.hidden = true;
      }

      function fetchPaletteData() {
        var overlay = document.getElementById('mimsy-palette');
        var basePath = overlay ? overlay.dataset.basepath : '';
        fetch('/api/mimsy/collections').then(function(r) { return r.json(); }).then(function(data) {
          var collections = data.collections || [];
          var promises = collections.map(function(col) {
            return fetch('/api/mimsy/content/' + col).then(function(r) { return r.json(); }).then(function(d) {
              return (d.entries || []).map(function(e) {
                return { collection: col, slug: e.slug, title: (e.frontmatter.title || e.frontmatter.name || e.slug), href: basePath + '/' + col + '/' + e.slug };
              });
            });
          });
          Promise.all(promises).then(function(results) {
            paletteCache = [];
            results.forEach(function(r) { paletteCache = paletteCache.concat(r); });
            paletteCacheTime = Date.now();
            var input = document.getElementById('mimsy-palette-input');
            if (input) renderPaletteResults(input.value);
          });
        }).catch(function() {});
      }

      var paletteActiveIdx = -1;

      function renderPaletteResults(query) {
        var container = document.getElementById('mimsy-palette-results');
        if (!container) return;
        paletteActiveIdx = -1;

        if (!paletteCache) {
          container.innerHTML = '<div class="mimsy-palette-empty">Loading…</div>';
          return;
        }

        var q = query.toLowerCase().trim();
        var filtered = paletteCache.filter(function(item) {
          if (!q) return true;
          return item.title.toLowerCase().indexOf(q) !== -1 || item.slug.toLowerCase().indexOf(q) !== -1 || item.collection.toLowerCase().indexOf(q) !== -1;
        });

        if (filtered.length === 0) {
          container.innerHTML = '<div class="mimsy-palette-empty">No results</div>';
          return;
        }

        // Group by collection
        var groups = {};
        filtered.forEach(function(item) {
          if (!groups[item.collection]) groups[item.collection] = [];
          groups[item.collection].push(item);
        });

        container.innerHTML = '';
        var idx = 0;
        Object.keys(groups).forEach(function(col) {
          var groupEl = document.createElement('div');
          groupEl.className = 'mimsy-palette-group';
          groupEl.textContent = col.charAt(0).toUpperCase() + col.slice(1);
          container.appendChild(groupEl);
          groups[col].forEach(function(item) {
            var itemEl = document.createElement('div');
            itemEl.className = 'mimsy-palette-item';
            itemEl.dataset.idx = idx;
            itemEl.dataset.href = item.href;
            var titleSpan = document.createElement('span');
            titleSpan.className = 'mimsy-palette-item-title';
            titleSpan.textContent = item.title;
            var slugSpan = document.createElement('span');
            slugSpan.className = 'mimsy-palette-item-slug';
            slugSpan.textContent = item.slug;
            itemEl.appendChild(titleSpan);
            itemEl.appendChild(slugSpan);
            container.appendChild(itemEl);
            idx++;
          });
        });
      }

      function navigatePaletteItem(href) {
        closePalette();
        // Use a real link click so Astro's View Transitions intercept it
        var a = document.createElement('a');
        a.href = href;
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        a.remove();
      }

      // Palette keyboard handler
      document.addEventListener('keydown', function(e) {
        var overlay = document.getElementById('mimsy-palette');
        if (!overlay) return;

        // Cmd+K to open
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (overlay.hidden) openPalette();
          else closePalette();
          return;
        }

        // Only handle these when palette is open
        if (overlay.hidden) return;

        if (e.key === 'Escape') {
          e.preventDefault();
          e.stopPropagation();
          closePalette();
          return;
        }

        var items = overlay.querySelectorAll('.mimsy-palette-item');
        if (!items.length) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          paletteActiveIdx = Math.min(paletteActiveIdx + 1, items.length - 1);
          items.forEach(function(el, i) { el.classList.toggle('mimsy-palette-active', i === paletteActiveIdx); });
          items[paletteActiveIdx].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          paletteActiveIdx = Math.max(paletteActiveIdx - 1, 0);
          items.forEach(function(el, i) { el.classList.toggle('mimsy-palette-active', i === paletteActiveIdx); });
          items[paletteActiveIdx].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter') {
          e.preventDefault();
          var active = paletteActiveIdx >= 0 ? items[paletteActiveIdx] : items[0];
          if (active) navigatePaletteItem(active.dataset.href);
        }
      });

      // Palette input handler
      document.addEventListener('input', function(e) {
        if (e.target.id === 'mimsy-palette-input') {
          renderPaletteResults(e.target.value);
        }
      });

      // Click on result or backdrop
      document.addEventListener('click', function(e) {
        var overlay = document.getElementById('mimsy-palette');
        if (!overlay || overlay.hidden) return;
        var item = e.target.closest('.mimsy-palette-item');
        if (item) {
          navigatePaletteItem(item.dataset.href);
          return;
        }
        // Click on backdrop (overlay itself, not the panel)
        if (e.target === overlay) closePalette();
      });

      // Invalidate on manual save/create/delete only — intentionally not on autosave.
      // Autosave fires every 1.5s while typing; busting the palette cache that frequently
      // would keep it permanently stale during editing sessions. Manual save is the
      // right signal: it's when a user considers content "done" and searchable.
      window.addEventListener('mimsy:mutate', function() {
        paletteCache = null;
      });

      // ── Deploy Button ──
      var deployBtn = document.getElementById('mimsy-deploy-btn');
      if (deployBtn) {
        deployBtn.addEventListener('click', function() {
          if (deployBtn.disabled) return;
          deployBtn.disabled = true;
          var textEl = deployBtn.querySelector('span');
          var originalText = textEl ? textEl.textContent : 'Deploy';
          if (textEl) textEl.textContent = 'Deploying…';
          fetch('/api/mimsy/deploy', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.ok) {
                window.dispatchEvent(new CustomEvent('mimsy:toast', { detail: { message: 'Deploy triggered!', type: 'success' } }));
              } else {
                window.dispatchEvent(new CustomEvent('mimsy:toast', { detail: { message: data.error || 'Deploy failed', type: 'error' } }));
              }
            })
            .catch(function() {
              window.dispatchEvent(new CustomEvent('mimsy:toast', { detail: { message: 'Deploy failed', type: 'error' } }));
            })
            .finally(function() {
              deployBtn.disabled = false;
              if (textEl) textEl.textContent = originalText;
            });
        });
      }
    }
  </script>
</body>
</html>

<style is:global>
  /* ── Design Tokens ── */
  .mimsy-admin {
    --mimsy-font-serif: 'Instrument Serif', Georgia, serif;
    --mimsy-font-sans: 'DM Sans', system-ui, sans-serif;
    --mimsy-font-mono: 'DM Mono', ui-monospace, monospace;
    --mimsy-accent: #7c3aed;
    --mimsy-accent-light: #ede9fe;
    --mimsy-accent-dark: #5b21b6;
    --mimsy-radius: 0.5rem;
    --mimsy-radius-sm: 0.375rem;
    font-family: var(--mimsy-font-sans);
  }

  /* ── Shared Form Tokens (plain CSS — no @apply for Tailwind v4 compat) ── */
  .mimsy-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    background-color: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 0.5rem;
    outline: none;
    transition: all 150ms ease;
    color: #1c1917;
  }
  .mimsy-input::placeholder { color: #a8a29e; }
  .mimsy-input:focus {
    border-color: #a78bfa;
    box-shadow: 0 0 0 2px #ede9fe;
  }

  /* ── Date Input ── */
  .mimsy-input[type="date"] {
    font-family: var(--mimsy-font-sans);
    position: relative;
    cursor: pointer;
  }
  .mimsy-input[type="date"]::-webkit-calendar-picker-indicator {
    cursor: pointer;
    border-radius: 0.25rem;
    padding: 0.25rem;
    margin-right: -0.25rem;
    opacity: 0.6;
    transition: opacity 150ms ease, background-color 150ms ease;
  }
  .mimsy-input[type="date"]::-webkit-calendar-picker-indicator:hover {
    opacity: 1;
    background-color: var(--mimsy-accent-light);
  }
  .mimsy-input[type="date"]::-webkit-datetime-edit {
    font-family: var(--mimsy-font-sans);
    color: #1c1917;
  }
  .mimsy-input[type="date"]::-webkit-datetime-edit-fields-wrapper {
    padding: 0;
  }
  .mimsy-input[type="date"]::-webkit-datetime-edit-text {
    color: #a8a29e;
    padding: 0 0.125rem;
  }
  .mimsy-input[type="date"]::-webkit-datetime-edit-month-field,
  .mimsy-input[type="date"]::-webkit-datetime-edit-day-field,
  .mimsy-input[type="date"]::-webkit-datetime-edit-year-field {
    font-family: var(--mimsy-font-sans);
    padding: 0.125rem 0.1875rem;
    border-radius: 0.1875rem;
  }
  .mimsy-input[type="date"]::-webkit-datetime-edit-month-field:focus,
  .mimsy-input[type="date"]::-webkit-datetime-edit-day-field:focus,
  .mimsy-input[type="date"]::-webkit-datetime-edit-year-field:focus {
    background-color: var(--mimsy-accent-light);
    color: var(--mimsy-accent-dark);
